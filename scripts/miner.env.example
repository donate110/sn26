#!/usr/bin/env bash
# Copy to scripts/miner.env and edit values before running:
#   cp scripts/miner.env.example scripts/miner.env
#   bash ./scripts/run_miner.sh

# Required
WALLET_NAME="miner"
WALLET_HOTKEY="default"

# Network
NETUID="1"
NETWORK="finney"
SUBTENSOR_CHAIN_ENDPOINT=""

# Optional
PYTHON_BIN="python3"
LOG_LEVEL="DEBUG"
AXON_IP="0.0.0.0"
AXON_PORT="8091"
AXON_EXTERNAL_IP=""
AXON_EXTERNAL_PORT="8091"
AXON_MAX_WORKERS="10"
MINER_EXTRA_ARGS=""
